% oprava stylu iso-authoryear
\ifboolexpr{test {\expandafter\ifstrequal\expandafter{\blx@bbxfile}{iso-authoryear}}}
	{% rok je uvedený ihned za jmény, ale přesné datum biblatex vynecháva
		% NEVYNECHÁVAT přesné datum, je nutné pro onlinové zdroje a vysílání (TV, rozhlas)
		\blxf@info{Fix for ISO author-year reference: print full date if specified}%
		\renewbibmacro*{date}{\iffieldundef{month}
			{\ifboolexpr{
				test {\iftoggle{bbx:url}}
				or test {\ifentrytype{online}}}
				{\adddot}% bez data, pouze datum citace → oddělit od [online] tečkou
				{}}
			{\printdate}}%
		% TODO/FIXME: přepínač pro toto nastavení + odkaz také jako Anon? + písmenka ke stejným rokům?
		% Použij Anon. jako autora, pokud není uveden:
		% Overwrite names:primary to print year right after:
		% 1) author
		% 2) editor
		% 3) NOT label/title BUT Anon.
		% Need to handle not to print editor twice (primary
		% and subsidiary names): editor macro includes \clearname{editor}
		\renewbibmacro*{names:primary}{%
			% First check if we have author(s) available
			\ifboolexpr{
				test \ifuseauthor
				and
				not test {\ifnameundef{author}}
			}
				{\usebibmacro{author}%
				 \setunit{\addspace}%
				 \printfield{nameaddon}%
				 \setunit{\printdelim{nameyeardelim}}}%
				{% If no author(s) is available, check for editor(s)
					\ifboolexpr{
						test \ifuseeditor
						and
						not test {\ifnameundef{editor}}
					}
						{\usebibmacro{editor}%
						 \setunit{\printdelim{nameyeardelim}}}%
						{% If no editor(s) is available, use Anon.
						 %\usebibmacro{labeltitle}%
						 %\setunit{\printdelim{nonameyeardelim}}%
						 Anon\adddot
						 }}%
			% And finally print date
			\usebibmacro{date+extradate}%
		}
		%% změna oddělovače jmen: výchozí je středník (;):
		%\renewcommand\multinamedelim{\addcomma\space}%	% čárka v citaci
		%\AtBeginBibliography{%							% středník v seznamu literatury
		%	\renewcommand\multinamedelim{\addsemicolon\space}%
		%}%
	}{}
	
% odstranění kurzivy pro název článku při chybějícím autorovi v harvardském stylu (iso-authoryear)
\renewbibmacro*{labeltitle}{%
	\iffieldundef{label}
		{\iffieldundef{shorttitle}
			{\iffieldundef{journaltitle}
				{\usebibmacro{titles}{}{emph}%
				 \clearfield{title}%
				 \clearfield{subtitle}%
				 \clearfield{titleaddon}}
				{\usebibmacro{titles}{}{}%
				 \clearfield{title}%
				 \clearfield{subtitle}%
				 \clearfield{titleaddon}}}
			{\printfield[title]{shorttitle}}}
		{\printfield{label}}}


% BibLaTeX: změna oddělovače jmen: výchozí je středník (;):
%	čárka (harvardský styl) v odkazech (cicacích)
%	v seznamu literatury pak středník (pomlčka)

% globálně (zejména odkazy):
\blxf@info{Setting global name delimiter to comma, i.e. for citations}
%\renewcommand\multinamedelim{\addsemicolon\space}			% středník (výchozí)
\renewcommand\multinamedelim{\addcomma\space}				% čárka

% pouze v seznamu literatury:
\AtBeginBibliography{%
	% změna oddělovače jmen: výchozí je středník (;):
	\blxf@info{Setting name delimiters in references to comma and `a'}
	\renewcommand\multinamedelim{\addsemicolon\space}		% středník
	%\renewcommand\multinamedelim{\addcomma\space}%			% čárka
	%\renewcommand\multinamedelim{\addnbspace--\addspace}%	% pomlčka
	% FIXME: Czech × English
	\renewcommand\finalnamedelim{\addspace\bibstring{and}\addnbspace}%	% mezi předposlední a poslední jméno
}

