\blxf@info{Adding nonbreak penalties to various places}
% nezalamovat rozsah stran, nezlomitelné mezery
\@ifl@ter{bbx}{iso}{2020/03/25}{% biblatex-iso690 ≥ 0.4.0
	% nezalamovat rozsah stran, nezlomitelná mezera
	\blxf@info{nb: page range}
	\DeclareFieldFormat[article,periodical]{pages}{%
		\iftoggle{bbx:shortnum}
			{\mbox{#1}}
			{\mkmlpageprefix[bookpagination]{\mbox{#1}}}}%
	% ISBN/ISSN/ISRN: nezlomitelně
	\blxf@info{nb: ISBN/ISSN/ISAN/ISMN/ISRN/ISWC}
	\DeclareFieldFormat{isbn}{%
		\def\do##1{\mkbibacro{ISBN}\penalty\value{isbnpenalty}\space\mbox{##1}%
			\def\do####1{\stdidentifierspunct\mkbibacro{ISBN}\penalty\value{isbnpenalty}\space\mbox{####1}}}%
		\docsvfield{isbn}}%
	\DeclareFieldFormat{issn}{%
		\def\do##1{\mkbibacro{ISSN}\penalty\value{isbnpenalty}\space\mbox{##1}%
			\def\do####1{\stdidentifierspunct\mkbibacro{ISSN}\penalty\value{isbnpenalty}\space\mbox{####1}}}%
		\docsvfield{issn}}%
	\DeclareFieldFormat{isan}{\mkbibacro{ISAN}\penalty\value{isbnpenalty}\addspace\mbox{#1}}
	\DeclareFieldFormat{ismn}{\mkbibacro{ISMN}\penalty\value{isbnpenalty}\addspace\mbox{#1}}
	\DeclareFieldFormat{isrn}{\mkbibacro{ISRN}\penalty\value{isbnpenalty}\addspace\mbox{#1}}
	\DeclareFieldFormat{iswc}{\mkbibacro{ISWC}\penalty\value{isbnpenalty}\addspace\mbox{#1}}
	\DeclareFieldFormat*{url}{%
		\iffieldundef{urlyear}
			{\mainlangbibstring{urlalso}}
			{\mainlangbibstring{urlfrom}}%
		\addcolon\addnbspace\url{#1}}%
}{% biblatex-iso690 < 0.4.0
	\blxf@info{nb: page range}
	\DeclareFieldFormat[article,periodical]{pages}{%
		\iftoggle{bbx:shortnum}
			{\mbox{#1}}
			{\mainsstring{pages}\addnbspace\printtext{\mbox{#1}}}}
	% ISBN/ISSN/ISRN: nezlomitelně
	\blxf@info{nb: ISBN/ISSN/ISRN}
	\DeclareFieldFormat{isbn}{\printtext{ISBN}\penalty\value{isbnpenalty}\space\mbox{#1}}
	\DeclareFieldFormat{issn}{\printtext{ISSN}\penalty\value{isbnpenalty}\space\mbox{#1}}
	\DeclareFieldFormat{isrn}{\printtext{ISRN}\penalty\value{isbnpenalty}\space\mbox{#1}}
}

% rozsahová pomlčka nezlomitelně
\blxf@info{nb: dash always nonbreakable}
\protected\def\bibrangedash{\mbox{\textendash}\penalty\@M}

% oprava \bibsstring → \bibstring
\@ifl@ter{bbx}{iso}{2020/03/25}{% biblatex-iso690 ≥ 0.4.0
	% ve verzi 0.4.0 již bibstring opraveno (poslal jsem záplatu a akceptovali ji)
	% nezlomitelná mezera mezi cit. a datum (\addnbspace), datum nedělit na více řádků (\mbox)
	\blxf@info{nb: between URL-seen-text and URL}
	% FIXME: nelze to nastavit v souboru lbx, tj. definovat string urlseen:
	%	urlseen = {{citováno}{cit\adddotspace}}% \adddotspace vkládá penaltu abbrv
	%
	\DeclareFieldFormat{urldate}{\mkbibbrackets{\mainlangbibstring{urlseen}\addnbspace#1}}
}{% biblatex-iso690 < 0.4.0
	\blxf@info{nb: volume/edition}
	\blxf@info{nb: between cited-text and date, date hyphens nonbreakable}
	\blxf@info{Fixes to short/long forms to depend on abbreviate option}
	\DeclareFieldFormat{volume}{\bibstring{volume}\addnbspace#1}% volume of a book
	\DeclareFieldFormat[article,periodical]{volume}{%
		\iftoggle{bbx:shortnum}
			{\mkbibbold{#1}}
			{\bibstring{jourvol}\addnbspace#1}}% volume of a journal
	\DeclareFieldFormat*{edition}{%
		\ifnumeral{#1}%
			{\mkbibordedition{#1}\addnbspace\bibstring{edition}}%
			{\MakeCapital{#1}}}%
	% nezlomitelná mezera mezi cit. a datum (\addnbspace), datum nedělit na více řádků (\mbox)
	\DeclareFieldFormat{urldate}{\mkbibbrackets{\mainsstring{urlseen}\addnbspace#1}}
}

% nezlomitelná mezera mezi zkratku „č.“ (nebo „číslo“) a číslo + oprava \bibsstring → \bibstring; 0.4.0 opravuje jen bibstring
\DeclareFieldFormat*{number}{\bibstring{number}\addnbspace\printtext{#1}}
\DeclareFieldFormat[article,periodical]{number}{%
	\iftoggle{bbx:shortnum}
		{\mkbibparens{#1}}
		{\bibstring{number}\addnbspace\printtext{#1}}}

\AtBeginBibliography{%
	% všechny spojovníky (-) nezlomitelné (EDTF/ISO používá \hyphen místo \nbhyphen)
	\blxf@info{Setting all biblatex hyphens nonbreakable (for dates)}
	\let\hyphen\nbhyphen
}

% odkazy na více zdrojů současně: čárka místo středníku a přidaná penalta mezi jednotlivé odkazy
\blxf@info{Redefining delimiter for multiple citations: comma + penalty}
\renewcommand*{\multicitedelim}{\addcomma%\addsemicolon
	\ifnumequal{\value{citecount}}{\value{citetotal}}%
		{\penalty\value{multicitefinaldelimpenalty}}%
		{\penalty\value{multicitedelimpenalty}}%
	\space}

% oprava: vlastní typy editorů (editorXtype) začínají velkým písmenem
\blxf@info{Redefining authority (like editor, translator) fields to start with uppercase}
\renewbibmacro*{bytypestrg}[2]{%
	\iffieldundef{#1type}
		{\bibstring{by#2}}
		{\ifbibxstring{by\thefield{#1type}}
			{\bibstring{by\thefield{#1type}}}
			{\printtext{\MakeCapital{\thefield{#1type}}}}}}

% oprava: poznámka začíná velkým písmenem
\blxf@info{Making first letter of reference note (comment) upper case}
\DeclareFieldFormat{note}{\MakeCapital{#1}\isdot}

