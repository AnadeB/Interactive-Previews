\blxf@info{Setting/defining additional penalties for biblatex}
\blxf@info{penalty between abbreviation and number: 10000}
\blxf@info{penalty in names (high, low): 10000, 9999}
\blxf@info{penalty between ISBN/ISSN and number: 2000}
\setcounter{abbrvpenalty}{10000}		% penalta mezi zkratkou a číslem
\setcounter{highnamepenalty}{10000}		% penalta za zlom ve jméně
\setcounter{lownamepenalty}{9999}		% penalta za zlom ve jméně
% nové hodnoty penalt
\newcounter{isbnpenalty}				% penalta za zlom mezi ISBN/ISSN a číslem
\setcounter{isbnpenalty}{2000}
\newcounter{multicitedelimpenalty}		% penalta za zlom mezi více odkazy
\newcounter{multicitefinaldelimpenalty}	% penalta za zlom mezi předposledním a posledním odkazem
\setcounter{multicitedelimpenalty}{200}
\setcounter{multicitefinaldelimpenalty}{10000}
\ifboolexpr{test {\expandafter\ifstrequal\expandafter{\blx@bbxfile}{iso-authoryear}}}
	{\setcounter{multicitedelimpenalty}{0}% pro harvardský styl není potřeba
	 \setcounter{multicitefinaldelimpenalty}{0}%
	 \blxf@info{penalty between multiple author-year citations: 0}%
	 \blxf@info{penalty before the last author-year citation: 0}%
	}{\blxf@info{penalty between multiple number citations: 200}%
	  \blxf@info{penalty before the last number citation: 10000}}

