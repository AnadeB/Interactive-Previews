% stylový soubor pro LaTeX
% opravná nastavení pro češtinu a biblatex pro ČSN ISO 690
% kódování zdroje: UTF-8
% (c) 2017–2020 Tomáš Hudec

% pomocí \usepackage[harvard]{biblatex-fixes}
% načte biblatex, volba harvard přepne styl odkazů na zdroje:
% výchozí je číslované odkazy, harvard zapne odkzy (jméno, rok)

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{biblatex-fixes}
	[2020/10/24 v1.0 BibLaTeX fixes by Tom Hudec]

% options
\RequirePackage{kvoptions}

\SetupKeyvalOptions{
	family=blxfix,
	prefix=blxf@,
	setkeys=\kvsetkeys,
}

\DeclareStringOption[iso-numeric]{style}%[iso-numeric]

\DeclareVoidOption{harvard}{\kvsetkeys{blxfix}{style=iso-authoryear}}

\DeclareLocalOptions{style,harvard}

\ProcessLocalKeyvalOptions*

\protected\def\blxf@info#1{\PackageInfo{biblatex-fixes}{#1\@gobble}}

\blxf@info{Setting default style for biblatex to \blxf@style}
\PassOptionsToPackage{
	style=\blxf@style,				% styl odkazů z volby balíku
}{biblatex}

\AtEndOfPackage{
	\DisableKeyvalOption[action=error,package=biblatex-fixes]{blxfix}{style}
	\DisableKeyvalOption[action=error,package=biblatex-fixes]{blxfix}{harvard}
}

