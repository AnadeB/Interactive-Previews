% oprava datezeros=false:
% BibLaTeX pro formát data iso vyžaduje datezeros=true, přestože je
% datum iso formátováno s nulami nezávisle na datezeros.

% Uložíme hodnotu datezeros nastavenou uživatelem
% a po kontrole a přenastavení biblatexem ji obnovíme na uživatelskou.
\newtoggle{user@blx@datezeros}
\AtEndPreamble{%
	\blxf@info{Saving value of biblatex's option datezeros
		(\iftoggle{blx@datezeros}{true}{false})}
	\iftoggle{blx@datezeros}% uložení uživatelova nastavení pro datezeros
		{\toggletrue{user@blx@datezeros}}
		{\togglefalse{user@blx@datezeros}}%
	\def\do#1{% kontrola, zda nějaký formát data je iso nebo edtf
		\ifcsstring{blx@dateformat@#1}{iso}
			{\nottoggle{blx@datezeros}% dočasně true, aby biblatex negeneroval varování
				{\setkeys{blx@opt@pre}{datezeros=true}}{}}{}%
		\ifcsstring{blx@dateformat@#1}{edtf}
			{\nottoggle{blx@datezeros}% dočasně true, aby biblatex negeneroval varování
				{\setkeys{blx@opt@pre}{datezeros=true}}{}}{}%
	}%
	\abx@dodates \do{labeldate}}

\usepackage[
	backend=biber,
	%style=iso-authoryear,				% Harvardský styl odkazů dle ISO 690
	%style=iso-numeric,					% číselný styl odkazů dle ISO 690
]{biblatex}

% pro zobrazování nastavení do logu, definováno v czechtypo
\def\blxf@saveShowKey{%
	\let\blxf@prevKeyType\showKeyType
	\let\blxf@prevShowInfo\showInfo
	\let\blxf@prevShowValuePre\showValuePre
	\let\blxf@prevShowValuePost\showValuePost
}
\def\blxf@restoreShowKey{%
	\let\showKeyType\blxf@prevKeyType
	\let\showInfo\blxf@prevShowInfo
	\let\showValuePre\blxf@prevShowValuePre
	\let\showValuePost\blxf@prevShowValuePost
}
\blxf@saveShowKey
\AtEndOfPackage{\blxf@restoreShowKey}

\ifx\showKeysAndExecute\undefined
	\let\showKeysAndExecute\relax
	\let\showKeysAndExecuteII\relax
\else
	\def\showKeyType{biblatex option}
	\let\showValuePre\@empty
	\let\showValuePost\@empty
	\let\showInfo\blxf@info
\fi

\blxf@info{Setting biblatex options}

\showKeysAndExecute
\ExecuteBibliographyOptions{
	%sorting=none,						% none → podle pořadí odkazů na zdroje
	%sortlocale=cs_CZ,					% řazení dle abecedy v tomto jazyce
	%bibencoding=auto,					% auto = (jako .tex), UTF8
	autolang=none,						% none|other – other = nastaví jazyk pro sazbu zdroje dle zdroje (podle langid)
	maxnames=9,							% maximální počet jmen
	minnames=3,							% je-li autorů více než maxnames, použije se jen minnames
	maxcitenames=1,						% maximální počet jmen v citaci (harvardský styl)
	mincitenames=1,
	datezeros=false,					% nuly (pouze formáty short a terse)
	date=short,
	%date=comp,							% iso = yyyy-mm-dd, comp: plné (dle jazyka)
	%alldates=comp,						% date, origdate, eventdate, urldate
	%urldate=edtf,						% (BibLaTeX ≥ 3.10: iso) formát pro datum citace
	dateabbrev=false,					% zkrácený formát měsíce (pouze formáty long a comp)
	datecirca=true,				    	% \datecircaprint před hrubým datem?
	dateuncertain=true,					% \(end)dateuncertainprint za nejistým datem?
	% pokud je v souboru bib např.: date = 1790?, date = 1700~ %(cca)
	shortnumeration=true,				% pro časopisy: true → svazek/ročník sázet tučně, číslo do závorky, false → slovně
	thesisinfoinnotes=false,			% false → typ VŠKP práce, instituce a vedoucí PŘED dostupnost (odkaz), true → jako poznámku v citaci (na konec)
	block=ragged,						% \raggedright pro bibliografii
	%giveninits=true,					% pouze iniciály jmen
	%abbreviate=false,			    	% zkratky / kratší verze: citováno
	abbreviate=true,			    	% zkratky / kratší verze: cit.
	pagetotal=true,				    	% zobrazovat celkový rozsah knihy (počet stran)
}
\AtEndPreamble{%
	\iftoggle{blx@datezeros}% je-li (po kontrole biblatexem) datezeros true
		{\nottoggle{user@blx@datezeros}% a bylo false, obnovíme false
			{\setkeys{blx@opt@pre}{datezeros=false}%
			\blxf@info{Restored value of biblatex's option datezeros
				(\iftoggle{blx@datezeros}{true}{false})}}{}}{}}%

\@ifpackagelater{biblatex}{2017/12/19}{% biblatex ≥ 3.10
	\showKeysAndExecute
	\ExecuteBibliographyOptions{
		urldate=iso,					% (BibLaTeX ≥ 3.10: iso) formát pro datum citace
		%seconds=false,			    	% uvádět sekundy v časech?
	}
}{% biblatex < 3.10
\@ifpackagelater{biblatex}{2016/09/10}{% biblatex ≥ 3.5
	\showKeysAndExecute
	\ExecuteBibliographyOptions{
		urldate=edtf,					% (BibLaTeX ≥ 3.10: iso) formát pro datum citace
		seconds=true,			    	% uvádět sekundy v časech? EDTF vyžaduje true
		%datezeros=true,				% EDTF vyžaduje true, nuly (pouze formáty short a terse)
	}
}{% biblatex < 3.5
	\showKeysAndExecute
	\ExecuteBibliographyOptions{
		urldate=iso8601,				% (BibLaTeX ≥ 3.10: iso) formát pro datum citace
	}
}}

