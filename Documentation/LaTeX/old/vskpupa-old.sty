\usepackage[raggedright]{titlesec}
% \titleformat*\sectioncommand{styling}	% změna stylu (fontů)
% \titleformat\sectioncommand[shape]{styling}{numbering}{label-sep}{before-code}[after-code]
% \titlespacing\sectioncommand{left}{before-sep}{after-sep}[right-sep]
\titleformat\section					% titulek 1. úrovně (kapitola) – \section
	{\raggedright\nohyphenation\sloppy\phantomsection\LARGE\bfseries}	% styl (písmo)
	{\thesection}						% číslo
	{1em}								% odsazení čísla od titulku
	{\MakeUppercase}					% titulky sekcí verzálkami
\titleformat*\subsection				% titulek 2. úrovně
	{\raggedright\nohyphenation\sloppy\phantomsection\Large\rmfamily\bfseries}
\titleformat*\subsubsection				% titulek 3. úrovně
	{\raggedright\nohyphenation\sloppy\phantomsection\large\rmfamily\bfseries}

% každá nová sekce začíná na nové straně
% balík titlesec umožňuje pomocí \sectionbreak nebo pomocí \titleclass
% nastavit titulek tak, aby automaticky začínal na nové straně
% – obojí ale generuje nesprávně odkazy (bookmarks) v PDF:
% ty pak odkazují místo na začátek sekce na konec textu na předchozí straně
% příklad pro \section:
%\def\sectionbreak{\clearpage}			% varianta 1
%\titleclass{\section}{top}				% varianta 2
% vlastní řešení, které funguje korektně i s PDF bookmarks:

% nečíslované titulky jako \section*{Titulek} nejsou v obsahu
% aby nebylo třeba používat \phantomsection, \pdfbookmark a \addcontentsline,
% redefinujeme \section* tak, že se bude titulek automaticky vkládat do obsahu
% a zároveň \section i \section* zahájí novou stranu

\newif\ifnosectionnumber				% nečíslovaný titulek sekce
\newif\ifpagesection					% \section zahajuje novou stranu
\def\handlestarsection{\@ifstar
	{\nosectionnumbertrue \@dblarg\handlesection}		% \section*
	{\nosectionnumberfalse\@dblarg\handlesection}}		% \section
\def\handlesection[#1]#2{%				% ošetřuje nečíslování a novou stránku
	\ifpagesection\clearpage\fi			% nová stránka
	\let\restoresecnumdepth\relax
	\ifnosectionnumber%\ifnum2=\c@secnumdepth
		\def\restoresecnumdepth{\setcounter{secnumdepth}{3}}
		\setcounter{secnumdepth}{0}%	% vypne číslování
		% pokud neexistuje \nameref, definujeme \ref pro nečíslovanou sekci jako název
		\ifx\nameref\undefined \protected@edef\@currentlabel{#1}\fi
	\fi%\fi
	\origsection[#1]{#2}\restoresecnumdepth}	% vloží titulek (a zapne číslování
\let\origsection\section				% původní \section kvůli redefinici
\let\section\handlestarsection			% zapnutí redefinované verze \section
\pagesectiontrue						% zapnutí nové stránky pro \section

% oprava obsahu po redefinici \section, aby nebyl titulek „Obsah“ v obsahu
\let\origtableofcontents\tableofcontents
\def\tableofcontents{%
	\let\origaddtocontents\addtocontents
	\def\addtocontents##1##2{}			% nezahrne řádek v obsahu, ale ponechá odkaz v záložkách PDF
	\origtableofcontents				% vloží obsah
	\let\addtocontents\origaddtocontents
}

