% všechna základní nastavení jsou v samostatném souboru:
% kódování, jazyk, rozměry papíru a okrajů, odkazy v PDF, titulky,
% řádkový rejstřík, stupeň písma pro tabulky a popisky, úprava výčtů, uvozovky
\RequirePackage{czechtypo}

\geometry{
	a4paper,							% rozměry papíru
	left=35mm,							% okraj zleva
	right=15mm,							% okraj zprava
	top=25mm,							% okraj shora
	includehead=false,					% nepočítat hlavičku do zrcadla
	bottom=25mm,						% okraj zdola
	includefoot=false,					% nepočítat patičku do zrcadla – paginace je tedy v okraji
}

\parindent=15pt							% odstavcová zarážka

\titleformat\section					% titulek 1. úrovně (kapitola) – \section
	{\raggedright\nohyphenation\sloppy\phantomsection
	\setbaseline[\LARGE]{\titleBaselineStretch}\bfseries\boldmath}	% styl
	{\thesection}						% číslo
	{1em}								% odsazení čísla od titulku
	{\MakeUppercase}					% titulky sekcí verzálkami

\pagesectiontrue						% zapnutí nové stránky pro \section

%\setcounter{secnumdepth}{3} 			% číslovat titulky pouze do této úrovně
\setcounter{tocdepth}{2}				% obsah generovat až do této úrovně

\fancypagestyle{plain}{					% redefinice stránkového stylu plain
	\fancyhf{}							% odstraní všechny elementy
	\renewcommand{\headrulewidth}{0pt}	% včetně linek
	\renewcommand{\footrulewidth}{0pt}
	\cfoot{\thepage}					% uprostřed dole číslo strany
	%\rfoot{\thepage}					% vpravo dole číslo strany
}

\setbaseline{1.5}						% řádkování 1,5

