% zahájení příloh pomocí \backmatter[formátování titulku]
\newcommand\backmatter[1][]{\clearpage\backmattertrue
	\setcounter{section}{0}%
	\renewcommand\thesection{\Alph{section}}%	% písmeno číslování
	\titleformat\section[block]					% formátování titulku přílohy (\section)
		{\raggedright\nohyphenation\sloppy\phantomsection
		 \setbaseline[\LARGE]{\titleBaselineStretch}\bfseries\boldmath}	% styl
		{Příloha~\thesection:}			% text + číslo (písmeno)
		{\wordsep}						% odsazení čísla od titulku
		%{.3333em plus .16667em} 		% odsazení čísla od titulku
		{#1}% \MakeUppercase
}
