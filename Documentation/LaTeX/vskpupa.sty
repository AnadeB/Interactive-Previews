% options
\RequirePackage{kvoptions}

\SetupKeyvalOptions{
	family=vskpUPa,
	prefix=vskpUPa@,
	setkeys=\kvsetkeys,
}

% výstup do PDF/A
\DeclareBoolOption[false]{pdfa}

% PDF/A vyžaduje metadata v XMP
% zápis metadat do \jobname.xmpdata podle \author, \title
\DeclareBoolOption[false]{writexmp}% write XMP metadata

% načíst biblatex s výchozím stylem podle hodnoty parametru
% \usepackage[biblatex]{vskpupa}			% biblatex, style=iso-numeric
% \usepackage[biblatex=num]{vskpupa}		% biblatex, style=iso-numeric
% \usepackage[biblatex=harvard]{vskpupa}	% biblatex, style=iso-authoryear
% \usepackage[biblatex=hodnota]{vskpupa}	% biblatex, style=hodnota
\DeclareStringOption{biblatex}[iso-numeric]
\let\vskpUPa@biblatex\relax					% výchozí hodnota bude \relax
% bez \relax se nedá rozlišit neuvedení volby a uvedení volby s prázdnou hodnotou

\DeclareVoidOption{harvard}{\kvsetkeys{vskpUPa}{biblatex=harvard}}

% podpora fontů Open Type a načtení Latin Modern ve formátu OTF
% pouze pro LuaLaTeX a XeLaTeX
\DeclareBoolOption[false]{otf}

\DeclareLocalOptions{writexmp,biblatex,harvard,otf}

\ProcessKeyvalOptions*

\ifvskpUPa@pdfa
	\PassOptionsToPackage{pdfa}{czechtypo}
\fi

\ifvskpUPa@writexmp
	\PassOptionsToPackage{writexmp}{czechtypo}
\fi

\ifvskpUPa@otf
	\PassOptionsToPackage{otf}{czechtypo}
\fi

\PackageInfo{vskpupa}{}%

\AtEndOfPackage{
	\DisableKeyvalOption[action=error,package=vskpupa]{vskpUPa}{pdfa}
	\DisableKeyvalOption[action=error,package=vskpupa]{vskpUPa}{biblatex}
}

\RequirePackage{etoolbox}				% podpora změn prostředí, testů, …

\AfterEndPreamble{% etoolbox: after \AtBeginDocument
	\DisableKeyvalOption[action=error,package=vskpupa]{vskpUPa}{writexmp}
}

