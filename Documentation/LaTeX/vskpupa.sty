\ifvskpUPa@writexmp

\AtBeginDocument{
	%\def\sep{,}
	%\pdfx@topdfstring\pdfx@Title\xmp@Title
	%\pdfx@topdfstring\pdfx@Author\xmp@Author
	%\pdfx@topdfstring\pdfx@Keywords\xmp@Keywords
	\begingroup
		\newwrite\xmp@data
		\immediate\openout\xmp@data=\jobname.xmpdata
		% \sep should be used for separating keywords or multiple authors
		\def\sep{\sep}		% default
		%\def\sep{, }		% nonstandard
		\writeSep\xmp@data\Title\@title
		\writeSep\xmp@data\Author\@author
		\writeSep\xmp@data\Keywords\@keywordsCZ
		\writeSep\xmp@data\Publisher\@university
		\writeSep\xmp@data\Subject\@thesisType
		\writeSep\xmp@data\Language{cs}
		\immediate\closeout\xmp@data
		\PackageInfo{vskpupa}{XMP data written}%
		\let\xmp@data\undefined
	\endgroup
	\global\advance\count17\m@ne
}

\fi

