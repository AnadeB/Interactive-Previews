\let\latexraggedright\raggedright
\newif\ifVSKPusesBibLaTeX
\ifx\vskpUPa@biblatex\relax				% nepoužívá se BibLaTeX:
	% pro jednotné uvádění odkazů (LaTeX i BibLaTeX) pomocí \autocite
	\let\autocite\cite
\else
	\VSKPusesBibLaTeXtrue
	\PackageInfo{vskpupa}{Setting default style for biblatex to \vskpUPa@biblatex}
	\PassOptionsToPackage{
		biblatex=\vskpUPa@biblatex,		% výchozí styl pro biblatex nastaví czechtypo
	}{czechtypo}
