% generování seznamu příloh
\newcommand{\listappendicesname}{Seznam příloh}
\newlistof{appendices}{apc}{\listappendicesname}

% příkaz \appendix pro titulek přílohy
\def\appendix{\@ifstar{\@dblarg\@appendixstar}{\@dblarg\@appendix}}
\def\@appendixstar[#1]#2{\section*[#1]{#2}\addcontentsline{apc}{appendices}{#1}}
\def\@appendix[#1]#2{\section[#1]{#2}\addcontentsline{apc}{appendices}{\protect\numberline{\thesection}#1}}


