% vlastní styl lze vložit jako výstup příkazu:
%	pygmentize -S <styl> -f latex -P commandprefix=PYG<styl>
% do podadresáře projektu: _minted-\jobname,
% což je pro overleaf: _minted-output
% alternativně lze načíst výstup příkzu pomocí následujícího makra
%	\loadMintedStyle[stylename]{stylefile}
% nepoviný argument je jméno stylu použité v souboru
% (makra v něm začínají prefixem \PYGstylename)
\newcommand\loadMintedStyle{\@dblarg\loadMintedStyle@}
\def\loadMintedStyle@[#1]#2{% očekává se jméno souboru
 	\ifstrempty{#1}{}{\ifcsname PYG\endcsname\else\minted@checkstyle{}\fi}%
	\expandafter\gdef\csname minted@styleloaded@#1\endcsname{}%
	\begingroup
		\let\def\gdef
		\catcode\string``=12
		\catcode`\_=11
		\catcode`\-=11
		\catcode`\%=14
		\endlinechar=-1\relax
		\minted@input{#2.tex}%
	\endgroup}


