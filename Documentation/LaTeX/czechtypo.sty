	\newcommand\tabraggedright{\RaggedRight\@raggedtwoe@spaceskipfalse\@raggedtwoe@everyselectfont}
	\newcommand\tabraggedleft{\RaggedLeft\@raggedtwoe@spaceskipfalse\@raggedtwoe@everyselectfont}
	\newcommand\tabcentering{\Centering\@raggedtwoe@spaceskipfalse\@raggedtwoe@everyselectfont}
	% umožní používat justyfying v tabulkách, kde je \\ definováno jinak
	\let\@raggedtwoe@justifying\justifying
	\newcommand\tabjustifying{\let\@raggedtwoe@savedcr\\ \@raggedtwoe@justifying}
}{
	% v tabulkách trochu jinak (mezislovní mezery pruží):
	\newcommand\tabraggedright[1][2em]{\rightskip\z@ plus #1\leftskip\z@skip}
	\newcommand\tabraggedleft[1][2em]{\rightskip\z@skip\leftskip\z@ plus #1\parindent\z@\parfillskip\z@skip}
	\newcommand\tabcentering{\leftskip\@flushglue\rightskip\leftskip\parindent\z@\parfillskip\z@skip}
	
	% vylepšené \raggedright (podle plainu): pevné mezery a pružnost vpravo jen na šířku 2em
	\renewcommand\raggedright[1][2em]{\let\\\@centercr\@rightskip\z@ plus #1\rightskip\@rightskip
	  \leftskip\z@skip \spaceskip=.3333em \xspaceskip=.5em % pevné mezery
	  \parindent\z@\normalparfillskip}
	% totéž pro \raggedleft
	\let\latexraggedleft\raggedleft
	\renewcommand\raggedleft[1][2em]{\let\\\@centercr \leftskip\z@ plus #1\rightskip\z@skip
		\spaceskip=.3333em \xspaceskip=.5em % pevné mezery
		\parindent\z@ \parfillskip\z@skip}
}
	
