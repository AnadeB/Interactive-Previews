% zatím jen vypne některá nekomatibilní nastavení
\@ifclassloaded{beamer}
	{\DeclareBoolOption[true]{beamer}}
	{\DeclareBoolOption[false]{beamer}}

% podpora fontů Open Type a načtení Latin Modern ve formátu OTF
% pouze pro LuaLaTeX a XeLaTeX
