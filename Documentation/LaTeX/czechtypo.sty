% TODO: Do budoucna použít \usepackage{SIunits} nebo \usepackage{siunitx}
\usepackage{units}						% jednotky pomocí \unit[hodnota]{jednotka}
% redefinice pomocí \thinspace místo původního \, (neboť velikost \, je níže předefinována)
\DeclareRobustCommand{\unitspace}{\ifthenelse{\boolean{B@UnitsLoose}}{~}{\thinspace}}
\DeclareRobustCommand*{\unit}[2][]{\notblank{#1}{#1\unitspace}{}%
	\ifmmode\mathrm{#2}\else{\upshape #2}\fi}
\DeclareRobustCommand*{\unitfrac}[3][]{\notblank{#1}{#1\unitspace}{}%
	\ifmmode\nicefrac[\mathrm]{#2}{#3}\else\nicefrac[\upshape]{#2}{#3}\fi}
