\usepackage{relsize}					% relativní změna velikosti fontu: \smaller[m], \larger[m], \relsize{m}

\newcommand\setskipamounts[1][\baselineskip]{%
	\dimen@=#1\relax
	\bigskipamount		= 1\dimen@ plus .333\dimen@ minus .333\dimen@
	\medskipamount		= \bigskipamount	\divide\medskipamount\tw@
	\smallskipamount	= \medskipamount	\divide\smallskipamount\tw@
	% odsazení popisků plovoucích objektů
	%\abovecaptionskip = .667\bigskipamount
	%\belowcaptionskip = -.667\bigskipamount
	\abovecaptionskip = .333\bigskipamount
	\belowcaptionskip = -.333\bigskipamount
	% odsazení plovoucích objektů umístěných [h] a [H]
	\intextsep			= 1.29\bigskipamount plus .167\dimen@ minus .167\dimen@
	% odsazení plovoucích objektů umístěných [t] a [b]
	\textfloatsep		= \intextsep
	% mezi plovoucími objekty [t] a [b]
	\floatsep			= 1.667\bigskipamount plus .667\bigskipamount minus .333\bigskipamount
	\advance\floatsep	-\belowcaptionskip
	% mezi plovoucími objekty [p]
	\@fpsep				= \floatsep
	% odsazení matematiky na samostatném řádku
	\abovedisplayskip	= 1\dimen@ plus .2\dimen@ minus .333\dimen@
	\belowdisplayskip	= \abovedisplayskip
	\abovedisplayshortskip	= \z@ plus .25\dimen@
	\belowdisplayshortskip	= .7\dimen@ plus .2\dimen@ minus .2\dimen@
}
\normalsize\setskipamounts
\AtBeginDocument{
	\normalsize\setskipamounts
}

% změna řádkování
\newlength\latex@footnotesep			% původní velikost footnotesep
\setlength\latex@footnotesep\footnotesep
\AtBeginDocument{\setlength\latex@footnotesep\footnotesep}
\newif\ifBaseLineStretchOne				% pro snadné testování řádkování 1
\BaseLineStretchOnetrue	
\newcommand\setBaselineStretch[2][\normalsize]{%
	\def\baselinestretch{#2}			% změna řádkování
	\def\tmp@ne{1}\ifx\baselinestretch\tmp@ne  \BaseLineStretchOnetrue
	\else \BaseLineStretchOnefalse \fi
	#1									% nastavení \baselineskip dle velikosti fontu
	\setskipamounts						% ekvivalentní změna vertikálních mezer
	\setlength\footnotesep{#2\latex@footnotesep}	% úprava mezery mezi poznámkami pod čaarou
}
\let\setbaseline\setBaselineStretch
