% FIXME: otestovat: \def\sectionbreak{\clearpage\phantomsection}
% Vlastní řešení, které funguje korektně i s PDF bookmarks:

% Nečíslované titulky jako \section*{Titulek} nejsou v obsahu.
% Aby nebylo třeba používat \phantomsection, \pdfbookmark a \addcontentsline,
% redefinujeme \section* tak, že se bude titulek automaticky vkládat do obsahu.
% Zároveň \section i \section* umožní začínat na nové straně.

\newif\ifnosectionnumber				% nečíslovaný titulek sekce
\newif\ifpagesection					% \section zahajuje novou stranu
\newif\ifbackmatter						% číslování příloh (article, thesis)
\def\handlestarsection{\@ifstar
	{\nosectionnumbertrue \@dblarg\handle@section}		% \section*
	{\nosectionnumberfalse\@dblarg\handle@section}}		% \section
\let\clearSection\cleardoublepage
\def\handle@section[#1]#2{%				% ošetřuje nečíslování a novou stránku
	\ifpagesection\clearSection\fi	% nová (lichá pro twoside) stránka
	\let\restoresecnumdepth\relax
	\ifnosectionnumber
		% zapamatuj si aktuální úroveň hloubky číslování titulků
        \edef\restoresecnumdepth{\noexpand\c@secnumdepth=\the\c@secnumdepth\relax}
		\c@secnumdepth=\z@				% vypne číslo titulku
		% pokud neexistuje \nameref, definujeme \ref pro nečíslovanou sekci jako název
		\ifx\nameref\undefined \protected@edef\@currentlabel{#1}\fi
		% pokud jsme v části příloh, zvýšíme číslo (písmeno) přílohy a vytvoříme referenci
		\ifbackmatter\refstepcounter{section}\fi
	\fi
	\latex@section[#1]{#2}				% vloží titulek původním makrem
	\restoresecnumdepth}				% obnoví číslování titulků
\let\latex@section\section				% původní \section kvůli redefinici
\ifcstyp@beamer\else
\let\section\handlestarsection			% zapnutí redefinované verze \section
\fi
