\ifcstyp@beamer\else
\geometry{
	a4paper,							% rozměry papíru
	left=25mm,							% okraj zleva
	right=25mm,							% okraj zprava
	top=25mm,							% okraj shora
	includehead=false,					% nepočítat hlavičku do zrcadla
	bottom=25mm,						% okraj zdola
	includefoot=false,					% nepočítat patičku do zrcadla – paginace je tedy v okraji
}
\fi
% Vztahy mezi parametry (a další možné parametry):
%               ↔ paperwidth                        [includehead=true]
%              ┌──────────────────────────────┐┈┈┈┈┈┬┈┈┈┈┈┬
% paperheight ↕│                              │     │top  │
%              │        ┌─────────────┐┈┈┈┈┈┈┈│┈┈┈┈┈┴     │
%              │        │   hlavička  │↕ headheight       │top [includehead=false]
%              │        └─────────────┘       │           │
%              │         ↕ headsep     marginparsep       │
%              │        ┌─────────────┐↔┌───┐ │┈┈┈┈┈┈┈┈┈┈┈┼
%              │        │             │ │   │ │           │
%              │←——————→│             │←—————→│           │ height = textheight +
%              │ left   │             │ right │           │ (+ headheight + headsep) [if includehead]
%              │(inner) │             │(outer)│           │ (+ footskip)             [if includefoot]
%              │        │↕ textheight │ │   │ │           │
%              │        │             │ │←—→│ │           │ width = textwidth +
%              │        │             │ │marginparwidth   │ (+ marginparsep
