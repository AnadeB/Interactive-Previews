%\usepackage{bookmark}
\hypersetup{
% viz http://ftp.cvut.cz/tex-archive/macros/latex/contrib/hyperref/doc/manual.html#x1-110003.7
	unicode,							% podpora UTF-8 v PDF (bookmarks, info)
	%bookmarks=true,					% generovat obsah PDF (bookmarks, výchozí je zapnuto)
	bookmarksnumbered=true,				% zahrnout čísla sekcí v obsahu PDF
	bookmarksopen=true,					% rozbalený strom obsahu (při otevření PDF)
	bookmarksopenlevel=3,				% počet úrovní rozbalení záložek
	colorlinks=true,					% zapnout barvy, vypnout rámečky
	% pozn.: rámečky se zobrazují pouze při prohlížení, netisknou se
	%hidelinks,							% vypne rámečky i při colorlinks=false
	% nastavení barev samostatně:
	% díky xcolors lze barvy „míchat“
	linkcolor=red!85!black,				% interní odkazy (křížové reference)
	citecolor=green!50!black,			% text odkazu na citaci
	filecolor=blue!67!cyan!80!black,	% URL pro lokální soubory
	urlcolor=blue!80!black,				% URL (orig.: magenta)
%	anchorcolor=black,					% cílový text
	% všechny barvy stejně:
	%allcolors=blue, 					% všechny odkazy (netýká se rámečků)
	%allbordercolors=blue,				% barvy všech rámečků kolem odkazů
	%linktocpage=false,					% v seznamech generovat odkaz pouze pro číslo strany
	linktoc=all,						% generovat odkaz v seznamech pro: text (section) – výchozí, číslo strany (page), obojí (all) nebo nic (none)
	pdfstartview=,						% výchozí zobrazení dle prohlížeče PDF
	pdfpagemode=,						% neotevírat záložky bookmarks/outline
}


