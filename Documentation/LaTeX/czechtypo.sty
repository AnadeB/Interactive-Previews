\let\latex@addtocontents\addtocontents
\def\contentsOff{\def\addtocontents##1##2{}}% nezahrne řádek v obsahu, ale ponechá odkaz v záložkách PDF
\def\contentsOn{\let\addtocontents\latex@addtocontents}

% oprava obsahu po redefinici \section, aby nebyl titulek „Obsah“ v obsahu
\AtBeginDocument{
