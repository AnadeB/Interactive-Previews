\usepackage{siunitx}[=v2]				% čísla a jednotky, lepší než units nebo SIunits

\cstyp@info{Setting siunitx options}
\def\showKeyType{siunitx option}
\showKeysAndExecute
\sisetup{
	%locale=CZ,							% zatím není podporována čeština
	%locale=DE,							% němčina je nejblíž, až na jazykové und, …
	binary-units=true,					% zapnout taky \bit, \byte a \kibi, \mebi, …
	number-unit-product={\text{\,}},	% mezera mezi číslem a jednotkou
	inter-unit-product={\mkern2mu},		% mezera pro násobení jednotek
	detect-family=true,					% přizpůsobí se písmu: serif, sans-serif, monospaced
	%detect-display-math=true,			% v $$…$$ fonty z matematiky
	%detect-inline-family=math,			% v $…$ fonty z matematiky
	detect-weight=true,					% v tučném textu tučně
	%detect-inline-weight=math,			% v $…$ tučnost z matematiky
	%detect-mode=true,					% font podle módu text/math
	retain-explicit-plus=true,			% neodstraňovat explicitní plus
	%retain-unity-mantissa=false,		% odstraňovat 1× v 1×10^{…}
	%retain-zero-exponent=true,			% neodstraňovat nulový exponent ×10^0
	group-digits=true,					% true, decimal, integer, false
	group-minimum-digits=4,				% seskupovat již od 4ciferných čísel
	group-separator={\,},				% v matem. režimu
	%input-decimal-markers={.,},		% desetinnné znaménko na vstupu
	%copy-decimal-marker=false,			% kopírovat vstupní na výstup
	output-decimal-marker={,},			% desetinná čárka
	exponent-product=\cdot,				% krát mezi mantisou a 10^{…}
	list-final-separator={ a },
	list-pair-separator={ a },
	list-separator={; },
	range-phrase={"--},
	number-angle-product={\mkern1mu},	% mezera mezi číslem a ° ′ ″
	%arc-separator={\,},				% mezera mezi ° ′ ″
	%arc-separator={\text{~}},			% mezera mezi ° ′ ″
	arc-separator={\text{\,}},			% mezera mezi ° ′ ″
	% symboly chráněné před expanzí při analýze čísel:
	%input-protect-tokens=\approx\dots\ge\geq\gg\le\leq\ll\mp\pi\pm\sim
	% pro tabulky
	table-number-alignment=center,		% sloupec S: řády pod sebe + zarovnávat na střed
	%table-text-alignment=center,		% sloupec S: {text} zarovnávat na střed
	%table-unit-alignment=center,		% sloupec s: jednotky zarovnávat na střed
	%table-alignment=center,			% všechny tři stejně: text, number, unit
}
