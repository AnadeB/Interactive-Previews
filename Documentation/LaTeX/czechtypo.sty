\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{czechtypo}
	[2020/11/02 v2.0 Czech typographic presets by Tom Hudec]
	%[2018/03/21 v1.0 Czech typographic presets by Tom Hudec]

% Obsahuje následující úpravy:
% • kódování UTF-8, podpora Unicode v PDF, písma Latin Modern,
% • čeština pomocí balíku babel + vypnutí aktivního spojovníku,
% • přidána zkratka pro nezalomitelný spojovník ("-),
% • nastavení zrcadla sazby pomocí balíku geometry,
% • podpora znaků: ‰, €, ½, ~, vzpřímené π,
% • barvy, dlouhé tabulky (přes více stran), sloupce,
% • úprava odstavcové zarážky a délky východového řádku,
% • úprava dělení slov (minimální počty znaků),
% • vylepšeno zalamování URL + přidána možnost snadného nastavení,
% • úzká mezera nastavena na ¼ čtverčíku (dle ČSN),
% • odkaz na poznámku pod čarou nemusí být číslo (\footnote*[symbol]{pozn.}),
% • titulky zarovnávány na levý okraj se zákazem dělení slov,
% • nečíslované titulky budou v obsahu (i PDF bookmarks),
% • sekce mohou začínat na nové straně (\pagesectiontrue),
% • nastaveno menší písmo tabulek a popisků (obrázků, tabulek),
% • upraveny vzdálenosti mezi plovoucími objekty (obrázky, tabulky),
% • umožněna snadná změna řádkování včetně odpovídajícího nastavení vertikálních mezer + mezery kolem matematiky (režim display),
% • odstraněna vertikální mezera kolem prostředí center,
% • upraveny (odstraněny) vertikální mezery ve výčtech, zákaz zalomení před výčtem,
% • mezi položkami výčtu lze snadno zakázat stránkový zlom (pomocí \par\nobreak),
% • nastaveny automatické „‚vnořené‘ uvozovky“,
% • přidány nové typy sloupců tabulek pro zarovnávání dle řádů.

% TODO
% • volbu pro \typoparfillskip a \normalparfillskip (výchozí?)
% • dopsat dokumentaci nastavení

% Změny:
% 2020-10-03: Změna definice v tabulkách: ! → : (array definuje ! jinak).
% 2020-10-25: Pro nastavení použit balík kvoptions.
% 2020-10-29: Přidán balík siunitx pro pokročilou sazbu čísel a jednotek.

