\ifx\cstyp@biblatex\relax \else
	\cstyp@info{Setting default style for biblatex to \cstyp@biblatex}
	\PassOptionsToPackage{
		style=\cstyp@biblatex,			% výchozí styl pro biblatex
	}{biblatex-fixes}\fi
	
\AtEndOfPackage{
	\DisableKeyvalOption[action=error,package=czechtypo]{cstypo}{pdfa}
	\DisableKeyvalOption[action=error,package=czechtypo]{cstypo}{beamer}
	\DisableKeyvalOption[action=error,package=czechtypo]{cstypo}{otf}
	\DisableKeyvalOption[action=error,package=czechtypo]{cstypo}{biblatex}
}

\AfterEndPreamble{% after \AtBeginDocument
	\DisableKeyvalOption[action=error,package=czechtypo]{cstypo}{writexmp}
}

% pro změnu parametrů
\newcommand\setupCzechTypo[1]{\kvsetkeys{cstypo}{#1}%
	\ifdefstring{\cstyp@parfillskip}{typo}{\kvsetkeys{cstypo}{parfillskip=typographic}}{}%
	\ifdefstring{\cstyp@parfillskip}{center}{\kvsetkeys{cstypo}{parfillskip=centered}}{}%
	\setParfillSkip
	\setTabularPadding
}

% zobrazování nastavení parametru pro setkeys/kvsetkeys
\long\def\showKeysAndExecute#1#2{\let\@tempc\@empty\showKeys{#2}#1{#2}}
\long\def\showKeysAndExecuteII#1#2#3{\def\@tempc{#2 }\showKeys{#3}#1{#2}{#3}}
\long\def\showKeys#1{\SK@do#1,\relax,}
\long\def\SK@do#1,{\ifx\relax#1\@empty\else\SK@split#1==\relax\expandafter\SK@do\fi}
\long\def\SK@split#1=#2=#3\relax{\KV@@sp@def\@tempa{#1}\ifx\@tempa\@empty\else
	\ifx\@empty#3\@empty\let\@tempb\@empty\else\KV@@sp@def\@tempb{#2}%
	\edef\@tempb{\showEqual\showValuePre\expandafter\detokenize\expandafter{\@tempb}\showValuePost}\fi
	\showInfo{\@tempc\ifx\showKeyType\@empty\else\showKeyType: \fi\@tempa\@tempb}\fi}
\def\showKeyType{czechtypo option}
\let\showValuePre\@empty
\let\showValuePost\@empty
\let\showInfo\cstyp@info
\def\showEqual{ = }

\AtEndOfPackage{
	\def\showKeyType{option}
	\let\showValuePre\@empty
	\let\showValuePost\@empty
	\protected\def\showInfo#1{\GenericInfo{}{Info: #1\@gobble}}%
}

