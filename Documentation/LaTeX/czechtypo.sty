% východový řádek odstavce by měl být široký alespoň 1,5× \parindent
% a na konci by měla být mezera alespoň 1em (viz Olšák: TeXbook naruby)
% nevýhody tohoto nastavení jsou, že je třeba je aktualizovat vždy při změně šířky \hsize
% a potlačí se výpočet \predisplaysize (nepracuje \abovedisplayshortskip)
\def\typoparfillskip{\ifdim\parindent=\z@ \normalparfillskip \else
	\parfillskip\hsize	% \textwidth ne, nefungovalo by to ve sloupcové sazbě
	\advance\parfillskip -1.5\parindent	% východový řádek musí být dlouhý alespoň 1,5× odsazení
	\advance\parfillskip 0pt minus \parfillskip
	\advance\parfillskip 0pt minus -1em\relax\fi}	% na konci východového řádku mezera ≥ 1em
\def\normalparfillskip{\parfillskip\@flushglue}

% s novým nastavením \parfillskip nefunguje \abovedisplayshortskip, protože TeX nenastaví \predisplaysize,
% pokud v \parfillskip pracuje stahování a roztahování nulté úrovně (bez fil)
% redefinice zahájení display módu s lokálním nastavením \parfillskip:
\let\latexDisplayMathStart\[
\let\latexDisplayMathStop \]
\def\[{\bgroup\normalparfillskip\latexDisplayMathStart}
\def\]{\latexDisplayMathStop\egroup\ignorespaces}
% aby to fungovalo, je třeba matematiku v režimu display zahajovat pomocí \[ místo $$

% vyznačování odstavců

% odstavcová zarážka
\def\normalparindent{\parindent1.5em\parskip\z@\setParfillSkip}
% vynechaný řádek (násobek řádku lze specifikovat volitelným parametrem, např. .5)
\newcommand\noparindent[1][1]{\parindent\z@		% bez zarážky, vynechaný řádek
	\dimen@ #1\baselineskip \parskip1\dimen@ plus .15\dimen@
	\normalparfillskip}

% do bloku + centrovaný východový řádek:
\def\centeredparfillskip{\leftskip\@flushglue\rightskip\z@ plus -1fil\relax
	\parfillskip\z@ plus 2fil\relax}
	
	
\newcommand\setParfillSkip{%
	\ifdefstring{\cstyp@parfillskip}{typographic}{\typoparfillskip}{%
	\ifdefstring{\cstyp@parfillskip}{centered}{\centeredparfillskip}{%
	\ifdefstring{\cstyp@parfillskip}{normal}{\normalparfillskip}{%
	\PackageError{czechtypo}{Unknown value for parfillskip. Allowed values:
	typographic, centered, normal or aliases: typo, center}}}}%
}

\AtBeginDocument{\setParfillSkip}
\def\multicolHook{\setParfillSkip}
\AtBeginEnvironment{multicols}{\multicolHook}

