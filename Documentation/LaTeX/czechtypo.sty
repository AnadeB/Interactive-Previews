% ZALAMOVÁNÍ V URL (vyžaduje \usepackage{url}, načítáno pomocí \usepackage{hyperref})

\def\resetURLchars{%					% zrušení výchozích zalamovacích znaků v URL
	\g@addto@macro\UrlOrds{\do\.\do\@\do\\\do\/\do\!\do\_\do\|\do\;\do\>\do\]%
		\do\)\do\,\do\?\do\&\do\'\do+\do\=\do\#\do\:%
		%\do\(\do\[\do\{\do\<
	}%
	\gdef\UrlNoBreaks{}%				% nemožnost zalomení za znakem: nic
	\gdef\UrlSpecials{\do\ {\Url@space}\do\^^M{\Url@space}% mezera zůstává speciální
		%\do\%{\Url@percent}			% procento neřešit
		\Url@force@Tilde}% package option may force faked text-ascii-tilde
	\gdef\UrlBreaks{}%					% možnost zalomení za znakem: nic
	\gdef\UrlBigBreaks{\do@url@hyp}%	% přednostní zalomení za znakem: nic
}
% nastaví kategorie speciálních znaků na obyčejné s výjimkou: \ { }
\def\URL@doBreakSpecial#1{\let\URL@doBreak\@makeother
	\ifnum`#1=`\{	\let\URL@doBreak\@gobble\fi
	\ifnum`#1=`\}	\let\URL@doBreak\@gobble\fi
	\ifnum`#1=`\\	\let\URL@doBreak\@gobble\fi
	\URL@doBreak{#1}}
\newif\ifURL@breakBefore
\newif\ifURL@breakPrefer
% nastaví pro URL znaky z parametrů: lze zalomit za znaky #1 a před znaky #2
% hvězdičková varianta: přednostní zalamování
\def\setURLbreaks{\begingroup\let\do\URL@doBreakSpecial\dospecials\@ifstar
	{\URL@breakPrefertrue \setURL@breaks}%
	{\URL@breakPreferfalse\setURL@breaks}}
\def\setURL@breaks#1#2{% #1: break after, #2: break before these characters
	\URL@breakBeforefalse	\let\next\setURL@break\next#1\relax
	\URL@breakBeforetrue	\let\next\setURL@break\next#2\relax\endgroup}
\def\setURL@break#1{\@ifnextchar\bgroup	% test optional count
	{\setURL@breakCount{#1}}%
	{\setURL@breakCount{#1}{\z@}}}
\def\setURL@breakCount#1#2{\ifx#1\relax \let\next\relax \else
	% DEBUG:
	%\par NEW: Allowing URL breaks \ifURL@breakBefore before\else after\fi
	%	\ the char {\ttfamily \string#1}%
	%	\ifnum#2>\z@~--~skip #2$\times$\fi\par
	\typeout{Allowing URL breaks \ifURL@breakBefore before\else after\fi
		\ the char \string#1\ifnum#2>\z@ -- skip #2times\fi}%
	\ifnum#2>\z@						% postpone allowing breaks
		\g@addto@macro\UrlSpecials{\doPostponeAllowBreak#1{#2}}%
		% define resetting macro: to be activated after #2 occurences of #1
		\ifURL@breakBefore
			\ifURL@breakPrefer	\setURL@char#1{\doAllowBreakBefore#1\relpenalty}\else
								\setURL@char#1{\doAllowBreakBefore#1\binoppenalty}\fi
		\else
			\ifURL@breakPrefer	\setURL@char#1{\@tempcnta"3000\set@mathcode#1}\else
								\setURL@char#1{\@tempcnta"2000\set@mathcode#1}\fi
		\fi
	\else
		\ifURL@breakBefore
			\ifURL@breakPrefer	\g@addto@macro\UrlSpecials{\doAllowBreakBefore#1\relpenalty}\else
								\g@addto@macro\UrlSpecials{\doAllowBreakBefore#1\binoppenalty}\fi
		\else
			\ifURL@breakPrefer	\g@addto@macro\UrlBigBreaks{\do#1}\else
								\g@addto@macro\UrlBreaks{\do#1}\fi
		\fi
	\fi
	\fi\next}
\def\doAllowBreakBefore#1#2{\mathcode`#1"8000\defActiveChar#1{\penalty#2\mathchar`#1}}
\def\defActiveChar#1{\bgroup \catcode`\~\active \lccode`\~`#1\lowercase{\egroup\def~}}
\def\setURL@chCnt#1{\expandafter\xdef\csname URL@postpone:#1\endcsname}%
\def\decURL@chCnt#1{\expandafter\count@\csname URL@postpone:#1\endcsname
	\advance\count@\m@ne \setURL@chCnt#1{\the\count@}}
\def\doPostponeAllowBreak#1#2{\mathcode`#1"8000\setURL@chCnt#1{#2}%
	\defActiveChar#1{\mathchar`#1\decURL@chCnt#1%
		\ifnum\count@>\z@\else \csname URL@char:#1\endcsname\fi}}
\def\setURL@char#1{\expandafter\gdef\csname URL@char:#1\endcsname}
