% Balík babel pro češtinu (a slovenštinu) nastavuje znak - jako aktivní (= definovaný jako příkaz, makro)
% (podpora automaticky se opakujícího spojovníku při rozdělení slova jako propan-butan ve švu).
% Bohůmžel aktivní spojovník znemožní používat některá makra, která využívají (neaktivní) spojovník.
% Jedná se např. o makra \cline{2-3}, \lipsum[1-5] aj.
% Taková makra se musí přepsat, aby používala aktivní verzi, nebo je třeba spojovníku vypnout aktivní stav.
\AtBeginDocument{
	\shorthandoff{-}					% spojovník nebude aktivní, lze znovu aktivovat pomocí \shorthandon{-}
}
\babeltags{en = english}				% česky \texten{English} česky \begin{en} English \end{en}
\babeltags{cs = czech}					% English \textcs{česky} English \begin{cs} česky \end{cs}

