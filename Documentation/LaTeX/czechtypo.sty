% VÝČTY: REDEFINICE PUNTÍKU a KOLEČKA, DEFINICE ČTVEREČKU
%
% redefinice puntíku a kolečka bez velké mezery kolem,
% kterou tam má znak v Latin Modern – \usepackage{lmodern};
% různé velikosti písma mají puntík bohůmžel jinak vysoko,
% posunutí na osu danou závorkami: dle výšky boxu s puntíkem se odvodí posun;
% výpočet je pouze aproximace skutečnosti
\let\latextextbullet\textbullet
\let\latextextopenbullet\textopenbullet
\def\get@vShift{\setbox\z@\hbox{\latextextbullet}\dimen@\ht\z@
	\ifdim\dimen@<4pt \dimen@=0.008\dimen@ \advance\dimen@.16pt\else	% ≤10pt
	\dimen@=-.15\dimen@ \advance\dimen@0.9pt\fi}	% >10pt
% Předefinovávat snadno nelze, protože symbol je definovaný tak,
% že v makru používá svůj název s prefixem jako příkaz,
% a ten by se musel předefinovat taky. Proto je definován nový symbol.
\DeclareRobustCommand\textBullet{\leavevmode\get@vShift
	\raise\dimen@\hbox to .3em{\hss\latextextbullet\hss}}
\DeclareRobustCommand\textOpenBullet{\leavevmode\get@vShift
	\raise\dimen@\hbox to .3em{\hss\latextextopenbullet\hss}}

% čtverečky (plný a prázdný) pro symboly do výčtů
\def\textsquaresize{.268em }
\def\mathsquaresize{.38em }

% TODO: makro \mathSquare
% TODO: \mathpalette?
% zatím se \textSquare chová v mat. režimu jako čtvereček velikost \bullet

% matematická osa je ve výšce \fontdimen22\font
% wd = \wd\z@, ht = \ht\z@ = osa + wd/2, dp = \dp\z@ = −osa + wd/2
% rulewd (tlošťka čáry) = \dimen@, margin = \dimen@ii
\def\get@squaredimens{\ifmmode\dimen@\mathsquaresize
	% výška matematické osy v metrice fontu
	\dimen@ii\fontdimen22\textfont2\else \dimen@\textsquaresize
	% osu v textovém režimu změříme dle závorky
	% (pro Latin Modern by mělo být stejné jako v matematice, cca 0,58 ex)
	\setbox\z@\hbox{()}\dimen@ii\ht\z@ \advance\dimen@ii\dp\z@
	\divide\dimen@ii\tw@ \dimen@ii-\dimen@ii \advance\dimen@ii\ht\z@ \fi
	\setbox\z@\null
	\wd\z@\dimen@ \divide\dimen@\tw@ \advance\dimen@\dimen@ii \ht\z@\dimen@
	\advance\dimen@-2\dimen@ii \dp\z@\dimen@ \dimen@.038em % tloušťka tahu
	\ifmmode \setbox\@ne\hbox{\m@th$\bullet$}\dimen@ii\wd\@ne\else \dimen@ii=.3em\fi
	\advance\dimen@ii-\wd\z@ \divide\dimen@ii\tw@}
\DeclareRobustCommand\textSquare{\get@squaredimens\leavevmode\kern\dimen@ii%
	\vrule width\wd\z@ height\ht\z@ depth\dp\z@\kern\dimen@ii}
\DeclareRobustCommand\textOpenSquare{\get@squaredimens\leavevmode\kern\dimen@ii%
	\setbox\@ne\vbox to\wd\z@{\hrule height\dimen@\kern-\dimen@\hbox to\wd\z@{%
	\vrule width\dimen@ height\wd\z@\hss\vrule width\dimen@}\kern-\dimen@\hrule height\dimen@}%
	\ht\@ne\ht\z@\dp\@ne\dp\z@\box\@ne\kern\dimen@ii}
\DeclareRobustCommand\textsquare{\ifmmode\setbox\z@\hbox{\m@th$\bullet$}%
	\hbox to\wd\z@{\hss\m@th$\textSquare$\hss}\else\get@vShift\leavevmode
	\raise-\dimen@\hbox to\wd\z@{\hss\textSquare\hss}\fi}
\DeclareRobustCommand\textopensquare{\ifmmode\setbox\z@\hbox{\m@th$\circ$}%
	\hbox to\wd\z@{\hss\m@th$\textOpenSquare$\hss}\else\get@vShift\leavevmode
	\raise-\dimen@\hbox to\wd\z@{\hss\textOpenSquare\hss}\fi}

