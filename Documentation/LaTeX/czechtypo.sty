% načíst biblatex s výchozím stylem podle hodnoty parametru
% \usepackage[biblatex]{czechtypo}			% biblatex, style=iso-numeric
% \usepackage[biblatex=num]{czechtypo}		% biblatex, style=iso-numeric
% \usepackage[biblatex=harvard]{czechtypo}	% biblatex, style=iso-authoryear
% \usepackage[biblatex=hodnota]{czechtypo}	% biblatex, style=hodnota
\DeclareStringOption{biblatex}[iso-numeric]
\let\cstyp@biblatex\relax					% výchozí hodnota bude \relax
% bez \relax se nedá rozlišit neuvedení volby a uvedení volby s prázdnou hodnotou

%\DeclareVoidOption{harvard}{\kvsetkeys{cstypo}{biblatex=iso-authoryear}}

% set \parfillskip to: typo/typographic, normal, center
